# Database Configuration
# For SQLite: sqlite:///./tasks.db
# For PostgreSQL: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./tasks.db

# JWT Security
# You should generate a strong random secret key for production: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-1234567890

# Token Settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
